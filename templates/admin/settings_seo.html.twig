{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}Réglages — SEO{% endblock %}

{% block main %}
<div class="kd">
    <div class="kd-panel" style="max-width: 720px; margin-bottom: 24px;">
        <h3 class="kd-panel__title">Image de partage (réseaux sociaux)</h3>
        <p style="color: var(--kd-navy-soft); margin-bottom: 18px; font-size: 0.9rem;">
            C'est l'aperçu affiché quand quelqu'un partage une page du site sur Facebook, LinkedIn, X, WhatsApp...
        </p>

        <div class="kd-favicon-preview" style="margin-bottom: 16px;">
            <img src="{{ settings.ogImageFilename ? asset('uploads/branding/' ~ settings.ogImageFilename) : asset('images/og-default.png') }}"
                 alt="Image de partage actuelle" style="width: 280px; height: auto; border-radius: 8px;">
        </div>
    </div>

    <div class="kd-panel" style="max-width: 720px;">
        <h3 class="kd-panel__title">Titres &amp; descriptions par page</h3>
        <p style="color: var(--kd-navy-soft); margin-bottom: 24px; font-size: 0.9rem;">
            Ce que Google (et les réseaux sociaux) affichent pour chacune de tes pages.
        </p>

        {{ form_start(form) }}
            {% for pageKey, pageLabel in {Home: 'Accueil', About: 'À propos', Services: 'Services', Contact: 'Contact'} %}
                <div style="border-top: 1px solid var(--kd-card-border); padding-top: 18px; margin-top: 18px;">
                    <p style="font-weight: 700; color: var(--kd-navy); margin-bottom: 12px;">{{ pageLabel }}</p>

                    {% set titleField = attribute(form, 'seo' ~ pageKey ~ 'Title') %}
                    {% set descField = attribute(form, 'seo' ~ pageKey ~ 'Description') %}

                    <div class="kd-form-row">
                        {{ form_label(titleField) }}
                        {{ form_widget(titleField) }}
                        {% if titleField.vars.help %}<p class="kd-form-help">{{ titleField.vars.help }}</p>{% endif %}
                        {{ form_errors(titleField) }}
                    </div>

                    <div class="kd-form-row">
                        {{ form_label(descField) }}
                        {{ form_widget(descField) }}
                        {% if descField.vars.help %}<p class="kd-form-help">{{ descField.vars.help }}</p>{% endif %}
                        {{ form_errors(descField) }}
                    </div>
                </div>
            {% endfor %}

            <div style="border-top: 1px solid var(--kd-card-border); padding-top: 18px; margin-top: 18px;">
                <div class="kd-form-row">
                    {{ form_label(form.ogImageFile) }}
                    {{ form_widget(form.ogImageFile) }}
                    {% if form.ogImageFile.vars.help %}<p class="kd-form-help">{{ form.ogImageFile.vars.help }}</p>{% endif %}
                    {{ form_errors(form.ogImageFile) }}
                </div>
            </div>

            <button type="submit" class="kd-btn">Enregistrer</button>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}

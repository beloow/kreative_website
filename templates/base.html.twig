{% set settings = site_settings() %}
{% set logoParts = settings.logoText|split('·') %}
{% set ogImageUrl = absolute_url(settings.ogImageFilename ? asset('uploads/branding/' ~ settings.ogImageFilename) : asset('images/og-default.png')) %}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}{{ settings.seoHomeTitle }}{% endblock %}</title>
    <meta name="description" content="{% block meta_description %}{{ settings.seoHomeDescription }}{% endblock %}">
    <link rel="canonical" href="{{ absolute_url(app.request.requestUri) }}">
    {% if settings.faviconFilename %}
        <link rel="icon" href="{{ asset('uploads/branding/' ~ settings.faviconFilename) }}">
    {% else %}
        <link rel="icon" href="{{ asset('favicon.svg') }}" type="image/svg+xml">
    {% endif %}

    {# Open Graph / réseaux sociaux #}
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="{{ settings.logoText }}">
    <meta property="og:title" content="{{ block('title')|striptags }}">
    <meta property="og:description" content="{{ block('meta_description')|striptags }}">
    <meta property="og:url" content="{{ absolute_url(app.request.requestUri) }}">
    <meta property="og:image" content="{{ ogImageUrl }}">
    <meta property="og:locale" content="fr_FR">

    {# Twitter / X #}
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ block('title')|striptags }}">
    <meta name="twitter:description" content="{{ block('meta_description')|striptags }}">
    <meta name="twitter:image" content="{{ ogImageUrl }}">

    {# Données structurées (JSON-LD) — aide Google à comprendre l'entreprise #}
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": {{ settings.logoText|json_encode|raw }},
        "url": {{ url('home')|json_encode|raw }},
        "logo": {{ ogImageUrl|json_encode|raw }},
        "description": {{ settings.seoHomeDescription|json_encode|raw }}
    }
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family={{ settings.siteFontHeading|url_encode }}:opsz,wght@9..144,500;9..144,600;9..144,700&family={{ settings.siteFontBody|url_encode }}:wght@400;500;600;700&family=IBM+Plex+Mono:wght@500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('css/style.css') }}">
    <link rel="stylesheet" href="{{ asset('css/theme-vars.css') }}">
    {% block stylesheets %}{% endblock %}
</head>
<body>
<header class="site-header">
    <div class="container site-header__inner">
        <a href="{{ path('home') }}" class="brand">
            <svg class="brand__mark" width="28" height="28" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect width="64" height="64" rx="14" fill="#11203A"/>
                <path d="M14 42 L26 28 L36 36 L50 18" stroke="var(--color-accent)" stroke-width="5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="50" cy="18" r="4" fill="var(--color-accent)"/>
            </svg>
            {% if logoParts|length == 2 %}
                {{ logoParts[0] }}<span class="brand__dot">·</span>{{ logoParts[1] }}
            {% else %}
                {{ settings.logoText }}
            {% endif %}
        </a>
        <nav class="nav">
            <button class="nav__toggle" id="navToggle" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="navPanel">
                <svg id="navToggleIcon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
            </button>
            <div class="nav__panel" id="navPanel">
                <ul class="nav__links">
                    <li><a href="{{ path('home') }}" class="{{ app.request.attributes.get('_route') == 'home' ? 'is-active' }}">Accueil</a></li>
                    <li><a href="{{ path('about') }}" class="{{ app.request.attributes.get('_route') == 'about' ? 'is-active' }}">À propos</a></li>
                    <li><a href="{{ path('service_index') }}" class="{{ app.request.attributes.get('_route') == 'service_index' ? 'is-active' }}">Services</a></li>
                    <li><a href="{{ path('contact') }}" class="{{ app.request.attributes.get('_route') == 'contact' ? 'is-active' }}">Contact</a></li>
                </ul>
                <a href="{{ path('contact') }}" class="btn btn--primary nav__cta">Discutons de votre projet</a>
            </div>
        </nav>
    </div>
</header>

<script>
    (function () {
        var toggle = document.getElementById('navToggle');
        var panel = document.getElementById('navPanel');
        if (!toggle || !panel) return;

        toggle.addEventListener('click', function () {
            var isOpen = panel.classList.toggle('is-open');
            toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        });

        // Ferme le menu automatiquement quand on clique sur un lien
        panel.querySelectorAll('a').forEach(function (link) {
            link.addEventListener('click', function () {
                panel.classList.remove('is-open');
                toggle.setAttribute('aria-expanded', 'false');
            });
        });
    })();
</script>

<main>
    {% for message in app.flashes('success') %}
        <div class="container" style="padding-top: 24px;">
            <div class="alert alert--success">{{ message }}</div>
        </div>
    {% endfor %}
    {% block body %}{% endblock %}
</main>

<footer class="site-footer">
    <div class="container site-footer__inner">
        <div>
            <div class="site-footer__brand">{{ settings.logoText }}</div>
            <p style="margin-top:6px;">Le marketing digital de votre PME, sans la lourdeur d'une équipe interne.</p>
        </div>
        <ul class="site-footer__links">
            <li><a href="{{ path('about') }}">À propos</a></li>
            <li><a href="{{ path('service_index') }}">Services</a></li>
            <li><a href="{{ path('contact') }}">Contact</a></li>
        </ul>
        <div>© {{ "now"|date('Y') }} {{ settings.logoText }}</div>
    </div>
</footer>
</body>
</html>
